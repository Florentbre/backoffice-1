# Choix du connecteur: google_unofficial (par défaut) ou generic
LOCATOR_PROVIDER=google_unofficial

# -------- Connecteur Google non officiel --------
# Endpoint Google (susceptible de changer sans préavis)
GOOGLE_FMD_URL=https://android.googleapis.com/nova/nbe_list_devices
GOOGLE_FMD_METHOD=POST
# Jeton Bearer (si nécessaire)
GOOGLE_FMD_AUTH_BEARER=
# Cookies de session Google (si nécessaires)
GOOGLE_FMD_COOKIE=
# Corps JSON attendu par l'endpoint
GOOGLE_FMD_BODY_JSON={}

# -------- Connecteur générique --------
LOCATOR_ENDPOINT_URL=https://example.com/api/lifetag/position
LOCATOR_API_TOKEN=
